# Never apply repository-only ignore rules to target machine.
.gitignore
dot_config/mpd/.gitignore

# Ignore common generated files in source state.
**/__pycache__/
*.pyc
*.pyo

{{- if eq .chezmoi.hostname "fedora" }}
# Host whitelist for fedora: ignore everything except selected targets.
*
!.config/
 .config/**
!.config/alacritty/
!.config/alacritty/alacritty.toml
!.config/ghostty/
!.config/ghostty/config
!.config/helix/
!.config/helix/config.toml
!.config/helix/languages.toml
!.config/niri/
!.config/niri/**
!.config/neovide/
!.config/neovide/config.toml
!.config/starship.toml
!.config/topgrade.toml
!.local/
 .local/**
!.local/bin/
!.local/bin/**
!.local/share/
!.local/share/**
!.ssh/
 .ssh/**
!.ssh/config
!.zimrc
!.zprofile
!.zshenv
!.zshrc
{{- end }}
