# Get editor completions based on the config schema
"$schema" = 'https://starship.rs/config-schema.json'

# Inserts a blank line between shell prompts
add_newline = true

continuation_prompt = "вЦґвЦґ"

# Prevent slow external commands from stalling the whole prompt (milliseconds)
command_timeout = 1000

# Configure the format of the prompt
format = """$os\
        $username \
        $sudo\
        $hostname\
        $shlvl\
        $kubernetes\
        $directory\
        $direnv\
        $git_branch\
        $git_commit\
        $git_state\
        $git_status\
        $git_metrics\
        $hg_branch\
        $docker_context\
        $package\
        (вЖУ Toolchain version modules вЖУ)\
        $buf\
        $bun\
        $c\
        $cmake\
        $meson\
        $crystal\
        $dart\
        $deno\
        $dotnet\
        $elixir\
        $erlang\
        $golang\
        $java\
        $kotlin\
        $gradle\
        $lua\
        $fennel\
        $nim\
        $haxe\
        $nodejs\
        $ocaml\
        $perl\
        $php\
        $python\
        $ruby\
        $rust\
        $swift\
        $vlang\
        $zig\
        (вЖС Toolchain version modules вЖС)\
        $memory_usage\
        $env_var\
        $custom\
        $cmd_duration\
        (вЖС above input line вЖС)\
        $line_break\
        (вЖУ on input line вЖУ)\
        $jobs\
        $battery\
        $time\
        $status\
        $character\
    """

# Prompt character module
[character]
success_symbol = '[вЭѓ](bold green)'
error_symbol = '[вЬЧ](bold red)'
vimcmd_symbol = "[вЭЃ](bold green)"
vimcmd_replace_symbol = "[вЭЃ](bold purple)"
vimcmd_replace_one_symbol = "[вЭЃ](bold purple)"
vimcmd_visual_symbol = "[вЭЃ](bold yellow)"

[battery]
full_symbol = "у∞Бє"
charging_symbol = "у∞ВД"
discharging_symbol = "у∞ВГ"
format = "[$symbol$percentage]($style) "
[[battery.display]]
threshold = 10
style = "bold red"

[cmd_duration]
format = '\[[пФ† $duration]($style)\]'
style = "bold cyan"
show_milliseconds = false
show_notifications = false
min_time = 2_000
min_time_to_notify = 45000

[directory]
format = "[пУУ $path]($style) [$read_only]($read_only_style) "
truncation_length = 3
truncate_to_repo = true
truncation_symbol = "../"
style = "underline bold green"
read_only = "у∞МЊ"
read_only_style = "italic red"

# Direnv indicator is very useful in monorepos (.envrc)
[direnv]
disabled = false

[hostname]
ssh_only = true
ssh_symbol = "у∞£А "
trim_at = "."
format = "[$hostname]($style) in "
style = " dimmed bold green"

[jobs]
threshold = 1
symbol_threshold = 1
number_threshold = 2
format = "[$symbol$number]($style) "
symbol = "вЬ¶"
style = "bold blue"

[line_break]
disabled = false

[memory_usage]
disabled = true
threshold = 75
format = '\[$symbol[$ram( | $swap)]($style)\] '
style = "bold dimmed white"
symbol = "у∞НЫ "

[os]
format = "[$symbol]($style) "
disabled = false
{{- if eq .chezmoi.osRelease.id "fedora" }}
style = "bold #3C6EB4"
{{- else if eq .chezmoi.osRelease.id "debian" }}
style = "bold #CE0058"
{{- else if eq .chezmoi.osRelease.id "gentoo" }}
style = "bold #DDDAEC"
{{- else }}
style = "bold #DDDAEC"
{{- end }}

[os.symbols]
Alpine = "пМА "
Amazon = "пЙ∞ "
Android = "пЕї "
Arch = "пМГ "
CentOS = "пМД "
Debian = "пМЖ "
DragonFly = "оКО "
Emscripten = "пИЕ "
EndeavourOS = "пЖЧ "
Fedora = "пМК "
FreeBSD = "пММ "
Garuda = "у∞ЫУ "
Gentoo = "пМН "
HardenedBSD = "у∞ЮМ "
Illumos = "у∞ИЄ "
Linux = "пМЪ "
Macos = "пМВ "
Manjaro = "пМТ "
Mariner = "пЗН "
MidnightBSD = "пЖЖ "
Mint = "пМО "
NetBSD = "пА§ "
NixOS = "пМУ "
OpenBSD = "у∞ИЇ "
openSUSE = "пМФ "
OracleLinux = "у∞МЈ "
Pop = "оК£ "
Raspbian = "пМХ "
Redhat = "пМЦ "
RedHatEnterprise = "пМЦ "
Redox = "пФЧ "
Solus = "у∞†≥ "
SUSE = "пМФ "
Ubuntu = "пМЫ "
Unknown = "пИ≠ "
Windows = "у∞Н≤ "

[package]
format = '\[[$symbol$version]($style)\]'
symbol = 'рЯУ¶ '
style = 'bold 214'
display_private = false

[shlvl]
disabled = true
threshold = 2
format = "[$symbol$shlvl]($style) "
symbol = "вЖХ"
style = "bold yellow"
repeat_offset = 0

[status]
format = "[$symbol$status]($style) "
style = "bold red"
symbol = "вЬЦ"
success_symbol = ""
not_executable_symbol = "пБЮ"
not_found_symbol = "пАВ"
sigint_symbol = "пБ±"
signal_symbol = "пАТ"
recognize_signal_code = true
map_symbol = false
pipestatus = false
pipestatus_separator = "|"
pipestatus_format = '\[$pipestatus\] '
pipestatus_segment_format = "[$symbol$status]($style)"

[sudo]
format = "[as $symbol]($style)"
style = "bold green"
symbol = "пГР "

# Show current shell (useful when switching bash/zsh/fish)
[shell]
disabled = false

[username]
style_user = "bold bright-white"
style_root = "red bold"
format = "[пАЗ $user]($style)"
disabled = false
show_always = true

# ----------------------------- Version control system ----------------------------
[git_status]
format = '([\[$all_status$ahead_behind\]]($style) )'
style = "red bold"
stashed = '\$'
ahead = "вЗ°"
behind = "вЗ£"
diverged = "вЗХ"
conflicted = "="
deleted = "вЬШ"
renamed = "¬ї"
modified = "!"
staged = "+"
untracked = "?"
ignore_submodules = true

[git_branch]
format = '\[[$symbol$branch]($style)\]'
symbol = "оЬ• "
style = "bold purple"
always_show_remote = true
only_attached = false
ignore_branches = []

[git_commit]
format = '[\($hash$tag\)]($style) '
style = "bold green"
only_detached = true
commit_hash_length = 7
tag_symbol = " у∞Ує  "
tag_disabled = false
tag_max_candidates = 0

[git_state]
format = '\([$state( $progress_current/$progress_total)]($style)\) '
style = "bold bright-yellow"
rebase = "REBASING"
merge = "MERGING"
revert = "REVERTING"
cherry_pick = "CHERRY-PICKING"
bisect = "BISECTING"
am = "AM"
am_or_rebase = "AM/REBASE"

# Already configured by you; now enabled in format for monorepo daily use
[git_metrics]
format = "([+$added]($added_style) )([-$deleted]($deleted_style) )"
added_style = "bold green"
deleted_style = "bold red"
only_nonzero_diffs = true
ignore_submodules = true

# Mercurial
[hg_branch]
format = 'on [$symbol$branch]($style) '
symbol = "у∞Шђ "
style = "bold purple"
truncation_length = 8                   # default = 2^63 - 1
truncation_symbol = "вА¶"
disabled = false

[pijul_channel]
format = 'on [$symbol$channel]($style) '
symbol = "оВ† "
style = "bold purple"
truncation_length = 10
truncation_symbol = "вА¶"
disabled = false

# ------------------------------------- Docker ------------------------------------
[docker_context]
format = '\[[$symbol$context]($style)\]'
symbol = 'у∞°® '
style = 'blue bold'
detect_files = ['docker-compose.yml', 'docker-compose.yaml', 'Dockerfile']

[kubernetes]
format = '\[[$symbol$context( \($namespace\))]($style)\]'
symbol = "вШЄ "
style = "cyan bold"

[container]
format = '\[[$symbol($version)]($style)\]'
symbol = 'пТЈ '
style = 'bold red dimmed'

[vagrant]
format = '\[[$symbol($version )]($style)\]'
symbol = "вН± "
style = "bold cyan"
detect_files = ["Vagrantfile"]

# ------------------------------ Language / Runtime ------------------------------
[buf]
format = '\[[$symbol($version)]($style)\]'
symbol = 'рЯРГ '
style = 'bold blue'
detect_files = ["buf.yaml", "buf.gen.yaml", "buf.work.yaml"]

[bun]
format = '\[[$symbol($version)]($style)\]'
symbol = 'рЯНЮ '
style = 'bold red'
detect_files = ["bun.lockb", "bunfig.toml"]

[c]
format = '\[[$symbol($version(-$name))]($style)\]'
symbol = "оШЮ "
style = 'bold 149'
commands = [["cc", "--version"], ["gcc", "--version"], ["clang", "--version"]]
detect_extensions = ["c", "h"]

[cmake]
format = '\[[$symbol($version)]($style)\]'
symbol = 'CMake '
style = 'bold red'
detect_files = ["CMakeLists.txt", "CMakeCache.txt"]

[crystal]
format = '\[[$symbol($version)]($style)\]'
symbol = 'оШѓ '
style = 'bold black'
detect_extensions = ["cr"]
detect_files = ["shard.yml"]

[dart]
format = '\[[$symbol($version)]($style)\]'
symbol = "оЮШ "
style = "bold blue"
detect_extensions = ["dart"]
detect_files = ["pubspec.yaml", "pubspec.yml", "pubspec.lock"]
detect_folders = [".dart_tool"]

[deno]
format = '\[[$symbol($version)]($style)\]'
symbol = 'рЯ¶Х '
style = 'green bold'
detect_files = [
  "deno.json",
  "deno.jsonc",
  "mod.ts",
  "deps.ts",
  "mod.js",
  "deps.js",
]

[dotnet]
format = '\[[$symbol($version)(рЯОѓ $tfm)]($style)\]'
symbol = "вАҐNET "
style = "blue bold"
heuristic = true
detect_extensions = ["csproj", "fsproj", "xproj"]
detect_files = [
  "global.json",
  "project.json",
  "Directory.Build.props",
  "Directory.Build.targets",
  "Packages.props",
]

[elixir]
format = '\[[$symbol($version \(OTP $otp_version\))]($style)\]'
symbol = "оШ≠ "
style = "bold purple"
detect_extensions = []
detect_files = ["mix.exs"]

[elm]
format = '\[[$symbol($version)]($style)\]'
symbol = "оШђ "
style = "bold blue dimmed"
detect_extensions = ["elm"]
detect_files = ["elm.json", "elm-package.json", ".elm-version"]
detect_folders = ["elm-stuff"]

[erlang]
format = '\[[$symbol($version)]($style)\]'
symbol = "оЮ± "
style = "bold red"
detect_extensions = []
detect_files = ["rebar.config", "erlang.mk"]

[fennel]
format = '\[[$symbol($version)]($style)\]'
symbol = 'рЯІЕ '
style = 'bold 121'
detect_extensions = ["fnl"]
detect_folders = ["fnl"]

[golang]
format = '\[[$symbol($version)]($style)\]'
symbol = "оШІ "
style = "bold cyan"
not_capable_style = "bold red"
detect_extensions = ["go"]
detect_files = [
  "go.mod",
  "go.sum",
  "go.work",
  "glide.yaml",
  "Gopkg.yml",
  "Gopkg.lock",
  ".go-version",
]
detect_folders = ["Godeps"]

[gradle]
format = '\[[$symbol($version)]($style)\]'
symbol = "оЩ† "
style = "bold bright-cyan"
detect_extensions = ["gradle", "gradle.kts"]
detect_folders = ["gradle"]

[haskell]
format = '\[[$symbol($version)]($style)\]'
symbol = "оЭЈ "
style = 'bold purple'
detect_extensions = ["hs", "cabal", "hs-boot"]
detect_files = ["stack.yaml", "cabal.project"]

[haxe]
format = '\[[$symbol($version)]($style)\]'
symbol = 'оЩ¶ '
style = "bold fg:202"
detect_extensions = ["hx", "hxml"]
detect_files = ["haxelib.json", "hxformat.json", ".haxerc"]
detect_folders = [".haxelib", "haxe_libraries"]

[java]
format = '\[[$symbol($version)]($style)\]'
symbol = "оЙЦ "
style = "red dimmed"
detect_extensions = ["java", "class", "jar", "gradle", "clj", "cljc"]
detect_files = [
  "pom.xml",
  "build.gradle.kts",
  "build.sbt",
  ".java-version",
  "deps.edn",
  "project.clj",
  "build.boot",
  ".sdkmanrc",
]

[julia]
format = '\[[$symbol($version)]($style)\]'
symbol = "аЃГ "
style = "bold purple"
detect_extensions = ["jl"]
detect_files = ["Project.toml", "Manifest.toml"]

[kotlin]
format = '\[[$symbol($version)]($style)\]'
symbol = 'оШі '
style = 'bold bright-blue'
detect_extensions = ["kt", "kts"]
kotlin_binary = "kotlin"

[lua]
format = '\[[$symbol($version)]($style)\]'
symbol = 'оШ† '
style = 'bold blue'
detect_extensions = ["lua"]
detect_files = [".lua-version"]
detect_folders = ["lua"]
lua_binary = "lua"

[meson]
format = '\[[$symbol$project]($style)\]'
symbol = 'Meson '
style = 'bold purple'
truncation_length = 10
truncation_symbol = "вА¶"

[nim]
format = '\[[$symbol($version)]($style)\]'
symbol = "оЩЈ "
style = "bold yellow"
detect_extensions = ["nim", "nims", "nimble"]
detect_files = ["nim.cfg"]

[nodejs]
format = '\[[$symbol($version)]($style)\]'
symbol = 'оЬШ '
style = "bold green"
detect_extensions = ["js", "mjs", "cjs", "ts", "mts", "cts", "jsx", "tsx"]
detect_files = [
  "package.json",
  ".node-version",
  ".nvmrc",
  ".pnp.cjs",
  ".pnp.loader.mjs",
]
detect_folders = ["node_modules"]

[ocaml]
format = '\[[$symbol($version)(\($switch_indicator$switch_name\))]($style)\]'
symbol = "оЩЇ "
style = "bold 208"
global_switch_indicator = ""
local_switch_indicator = "*"
detect_extensions = ["opam", "ml", "mli", "re", "rei"]
detect_files = ["dune", "dune-project", "jbuild", "jbuild-ignore", ".merlin"]
detect_folders = ["_opam", "esy.lock"]

[perl]
format = '\[[$symbol($version)]($style)\]'
symbol = "оЭ© "
style = "bold 149"
detect_extensions = ["pl", "pm", "pod"]
detect_files = [
  "Makefile.PL",
  "Build.PL",
  "cpanfile",
  "cpanfile.snapshot",
  "META.json",
  "META.yml",
  ".perl-version",
]

[php]
format = '\[[$symbol($version)]($style)\]'
symbol = 'оШИ '
style = "bold 147"
detect_extensions = ["php"]
detect_files = ["composer.json", ".php-version"]

[purescript]
format = '\[[$symbol($version)]($style)\]'
symbol = "оШ∞ "
style = "bold white"
detect_extensions = ["purs"]
detect_files = ["spago.dhall"]

[python]
format = '\[[${symbol}${pyenv_prefix}(${version})(\($virtualenv\))]($style)\]'
symbol = "оШЖ "
style = "bold yellow"
pyenv_version_name = false
pyenv_prefix = "pyenv "
python_binary = ["python", "python3"]
detect_extensions = ["py"]
detect_files = [
  "requirements.txt",
  ".python-version",
  "pyproject.toml",
  "Pipfile",
  "tox.ini",
  "setup.py",
  "__init__.py",
]

[rlang]
format = '\[[$symbol($version)]($style)\]'
symbol = "у∞ЯФ "
style = "blue bold"
detect_extensions = ["R", "Rd", "Rmd", "Rproj", "Rsx"]
detect_files = [".Rprofile"]
detect_folders = [".Rproj.user"]

[raku]
format = '\[[$symbol($version-vm_version)]($style)\]'
symbol = "рЯ¶Л "
style = "bold 149"
detect_extensions = ["p6", "pm6", "pod6", "raku", "rakumod"]
detect_files = ["META6.json"]

[ruby]
format = '\[[$symbol($version)]($style)\]'
symbol = "оЬє "
style = "bold red"
detect_extensions = ["rb"]
detect_files = ["Gemfile", ".ruby-version"]

[rust]
format = '\[[$symbol($version)]($style)\]'
symbol = 'рЯ¶А '
style = "bold 124"
detect_extensions = ["rs"]
detect_files = ["Cargo.toml"]

[scala]
format = '\[[$symbol($version)]($style)\]'
symbol = "оЬЈ "
style = 'bold red dimmed'
detect_extensions = ["sbt", "scala"]
detect_files = [".scalaenv", ".sbtenv", "build.sbt"]
detect_folders = [".metals"]

[solidity]
format = '\[[$symbol($version)]($style)\]'
version_format = "v${major}.${minor}.${patch}"
symbol = "S "
style = "bold 19"
compiler = ["solc"]
detect_extensions = ["sol"]

[swift]
format = '\[[$symbol($version)]($style)\]'
symbol = 'оЭХ '
style = "bold 202"
detect_extensions = ["swift"]
detect_files = ["Package.swift"]

[vlang]
format = '\[[$symbol($version)]($style)\]'
symbol = "оЪђ "
style = "bold 69"
detect_extensions = ["v"]
detect_files = ["v.mod", "vpkg.json", ".vpkg-lock.json"]

[zig]
format = '\[[$symbol($version)]($style)\]'
symbol = 'вЖѓ '
style = 'bold bright-yellow'
detect_extensions = ["zig"]
