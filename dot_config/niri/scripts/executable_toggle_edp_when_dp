#!/usr/bin/env bash
set -euo pipefail

DP_NAME="DP-1"
EDP_NAME="eDP-1"

niri_try() {
    niri msg "$@" >/dev/null 2>&1 || true
}

notify() {
    local title="$1"
    local body="$2"

    if command -v notify-send >/dev/null 2>&1; then
        notify-send -a "niri" -i "video-display" "$title" "$body" >/dev/null 2>&1 || true
        return 0
    fi

    printf '%s: %s\n' "$title" "$body"
}

dp_connected() {
    niri msg outputs 2>/dev/null | grep -Fq "$DP_NAME"
}

edp_present() {
    niri msg outputs 2>/dev/null | grep -Fq "$EDP_NAME"
}

ensure_layout() {
    niri_try output "$EDP_NAME" on
    niri_try output "$EDP_NAME" mode "1920x1080@144"
    niri_try output "$EDP_NAME" position 0 0
    if dp_connected; then
        niri_try output "$DP_NAME" on
        niri_try output "$DP_NAME" mode "2560x1440@180"
        niri_try output "$DP_NAME" position 1920 0
    fi
}

disable_edp() {
    niri_try output "$EDP_NAME" off
}

workspace_refs() {
    niri msg workspaces 2>/dev/null \
        | awk '
            {
                while (match($0, /[0-9]+/)) {
                    n = substr($0, RSTART, RLENGTH)
                    if (n >= 1 && n <= 100) seen[n] = 1
                    $0 = substr($0, RSTART + RLENGTH)
                }
            }
            END {
                for (k in seen) print k
            }
        ' \
        | sort -n
}

move_all_workspaces_to() {
    local target="$1"
    local moved=false

    while read -r ws; do
        [[ -z "$ws" ]] && continue
        niri_try action move-workspace-to-monitor "$target" --reference "$ws"
        moved=true
    done < <(workspace_refs)

    if [[ "$moved" == false ]]; then
        local ws
        for ws in {1..10}; do
            niri_try action move-workspace-to-monitor "$target" --reference "$ws"
        done
    fi

    niri_try action focus-monitor "$target"
}

main() {
    if dp_connected; then
        if edp_present; then
            # Toggle OFF: disable eDP-1 and move workspaces to DP-1.
            move_all_workspaces_to "$DP_NAME"
            disable_edp
            notify "Display toggled" "DP-1 connected. Moved workspaces to DP-1 and disabled eDP-1."
        else
            # Toggle ON: re-enable eDP-1 and restore layout.
            ensure_layout
            move_all_workspaces_to "$EDP_NAME"
            notify "Display toggled" "DP-1 connected. Enabled eDP-1 and moved workspaces to eDP-1."
        fi
    else
        ensure_layout
        move_all_workspaces_to "$EDP_NAME"
        notify "Display toggled" "DP-1 not connected. Restored eDP-1 layout and moved workspaces to eDP-1."
    fi
}

main
