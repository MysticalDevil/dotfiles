#! /usr/bin/env bash

## General -----------------------------------------------#

## Bspwm config directory
BSPDIR="$HOME/.config/bspwm"

"$BSPDIR"/autostart.bash &

## Run java applications without issues
export _JAVA_AWT_WM_NONREPARENTING=1
#wmname LG3D

## Current theme -----------------------------------------#
source "$BSPDIR"/themes/dracula.bash


## Get the colors from theme file
# FOREGROUND="$foreground"
BACKGROUND="$background"
# CURSOR="$cursor"
# BLACK="$color0"
# RED="$color1"
GREEN="$color2"
# YELLOW="$color3"
BLUE="$color4"
MAGENTA="$color5"
# CYAN="$color6"
# WHITE="$color7"
# ALTBLACK="$color8"
# ALTRED="$color9"
# ALTGREEN="$color10"
# ALTYELLOW="$color11"
# ALTBLUE="$color12"
# ALTMAGENTA="$color13"
# ALTCYAN="$color14"
# ALTWHITE="$color15"

## Configurations ----------------------------------------#

## Manager Workspaces
workspaces() {
  name=1
  for monitor in $(bspc query -M); do
    # bspc monitor -d I II III IV V VI VII VIII IX X
    bspc monitor "$monitor" -n "$name" -d 'яТЙ ' 'яЙй ' 'яБ╝ ' 'яДб ' 'яАн ' 'яВЖ ' 'яЕк ' 'яР╖ ' 'яАУ '
    (( name++ ))
  done
}
workspaces

## Apply bspwm configurations
bspc config border_width           2
bspc config window_gap             12
bspc config split_ratio            0.52

bspc config focused_border_color   "$BLUE"
bspc config normal_border_color    "$BACKGROUND"
bspc config active_border_color    "$MAGENTA"
bpsc config presel_feedback_color  "$GREEN"

bspc config borderless_monocle     true
bspc config gapless_monocle        true
bspc config paddingless_monocle    true
bspc config single_monocle         false
bspc config focus_follows_pointer  true

## Window rules ------------------------------------------#
# removw all rules first
bspc rule -r -- *glob*

## 1 > Terminal (alaways open terminal on workspace-1)
bspc rule -a Alacritty desktop='^1' follow=on focus=on
bspc rule -a Kitty desktop='^1' follow=on focus=on
bspc rule -a WezTerm desktop='^1' follow=on focus=on

## 2 > Browser (always open terminal on workspace-2)
bspc rule -a firefox desktop='^2' follow=on focus=on
bspc rule -a firefox:Places follow=on focus=on state=floating
bspc rule -a firefox:browser follow=on focus=on state=floating
bspc rule -a firefox:Devtools follow=on focus=on state=floating

bspc rule -a Google-chrome desktop='^2' follow=on focus=on
bspc rule -a Google-chrome:Places follow=on focus=on state=floating
bspc rule -a Google-chrome:browser follow=on focus=on state=floating
bspc rule -a Google-chrome:Devtools follow=on focus=on state=floating

## 3 > Files (always open file manager on workspace-3)
declare -a files=(Thunar qBittorrent)
for i in "${files[@]}"; do
  bspc rule -a "$i" desktop='^3' follow=on focus=on
done

## 4 > Code (always open editors on workspace-4)
declare -a code=(Code Subl neovide)
for i in "${code[@]}"; do
  bspc rule -a "$i" desktop='^4' follow=on focus=on
done

## 5 > office and docs (always open office/doc apps on workspace-5)
declare -a office=(Gucharmap Atril Evince \
libreoffice-writer libreoffice-calc libreoffice-impress \
libreoffice-startcenter libreoffice Soffice *:libreofficedev *:soffice)
for i in "${office[@]}"; do
   bspc rule -a "$i" desktop='^5' follow=on focus=on
done

## 6 > communication (always open communication apps on workspace-6)
declare -a comm=(Thunderbird TelegramDesktop)
for i in "${comm[@]}"; do
   bspc rule -a "$i" desktop='^6' follow=on focus=on
done
bspc rule -a TelegramDesktop desktop='^6'  state=floating

## 7 > media (always open media apps on workspace-7)
declare -a media=(Audacity Music Inkscape mpv yesplaymusic vlc spotify obs)
for i in "${media[@]}"; do
   bspc rule -a "$i" desktop='^7' state=floating follow=on focus=on
done

## 8 > Graphic Design (alweys open video editor on worksspace-8)
declare -a editor=(kdenlive OpenToonz resolve Fusion Blender mystiq Gimp-2.10 krita Natron)
for i in "${editor[@]}"; do
  bspc rule -a "$i" desktop='^8' state=tiled follow=on focus=on
done
bspc rule -a Blender state=tiled
bspc rule -a resolve state=tiled

## 9 > system (always open system apps on workspace-9)
bspc rule -a 'VirtualBox Manager' desktop='^9' follow=on focus=on
bspc rule -a GParted desktop='^9' follow=on focus=on
declare -a settings=(Lxappearance Lxtask Lxrandr Arandr \
System-config-printer.py Pavucontrol Exo-helper-1 \
Xfce4-power-manager-settings)
for i in "${settings[@]}"; do
   bspc rule -a "$i" desktop='^9' state=floating follow=on focus=on; d focus=on sttate=tile
done

## Always Floating Apps
declare -a floating=(fdm alacritty-float Pcmanfm Thunar qv2ray kitty Onboard Yad 'Firefox:Places' FusionRenderNode \
Viewnior  persepolis marktext  feh Nm-connection-editor mystiq clash-verge)
for i in "${floating[@]}"; do
   bspc rule -a "$i" state=floating follow=on focus=on
done
bspc rule -a Conky state=floating manage=off
bspc rule -a stalonetray state=floating manage=off
