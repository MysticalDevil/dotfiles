{
  // ======================================= Editor config ========================================
  "editor.bracketPairColorization.enabled": true, // 彩虹括号
  "editor.codeLensFontFamily": "Jetbrains Mono",
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.fontFamily": "'Fira Code', 'Jetbrains Mono', 'Space Mono', 'Source Code Pro', 'DejaVu Sans Mono', 'Source Code Pro', Consolas, 'Courier New', 'Hack Nerd Font'",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.fontWeight": "normal",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.guides.bracketPairs": "active",
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,
  "editor.rulers": [120],
  "editor.suggestSelection": "first",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true
  },
  // Language setting
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [80],
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": false
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-docker"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[vue]": {
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua"
  },
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "[ruby]": {
    "editor.defaultFormatter": "Shopify.ruby-lsp",
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.insertSpaces": true,
    "editor.semanticHighlighting.enabled": true,
    "editor.tabSize": 2
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.tabSize": 2
  },
  "[rust]": {
    "editor.semanticHighlighting.enabled": false
  },
  // ====================================== Terminal config =======================================
  "terminal.integrated.commandsToSkipShell": ["language-julia.interrupt"],
  "terminal.integrated.defaultProfile.linux": "zsh (migrated)",
  "terminal.integrated.profiles.linux": {
    "zsh (migrated)": {
      "args": [],
      "path": "zsh"
    }
  },
  "terminal.integrated.smoothScrolling": true,
  // ====================================== Workbench config ======================================
  "workbench.colorCustomizations": {
    "editor.bracketPairColorization.enabled": true
  },
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.list.smoothScrolling": true,
  // ======================================== Files config ========================================
  "files.associations": {
    "*.tpl": "html",
    ".zimrc": "shellscript"
  },
  "files.autoSave": "afterDelay",
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  // ========================================= Git config =========================================
  "git.autofetch": true,
  "git.confirmSync": false,
  // ====================================== Explorer config =======================================
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  // ======================================== Other config ========================================
  "security.workspace.trust.untrustedFiles": "open",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  // ======================================= Plugin config ========================================
  "auto-close-tag.activationOnLanguage": [
    "javascript",
    "javascriptreact",
    "html",
    "xml",
    "php"
  ],
  "dev.containers.executeInWSL": true,
  "go.toolsManagement.autoUpdate": true,
  "haskell.manageHLS": "GHCup",
  "open-in-browser.default": "chrome",
  // 使用 prettier 格式化 js/ts 的配置
  "prettier.singleQuote": true,
  "prettier.semi": false,
  "redhat.telemetry.enabled": true,
  "settingsSync.ignoredExtensions": [
    "ms-dotnettools.csharp",
    "tauri-apps.tauri-vscode",
    "xadillax.viml",
    "thenuprojectcontributors.vscode-nushell-lang",
    "budparr.language-hugo-vscode",
    "xlthu.pangu-markdown"
  ],
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  // ========================================= VSCode Vim =========================================
  "vim.leader": ",",
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.useSystemClipboard": true,
  "vim.handleKeys": {
    "<C-a>": true,
    "<C-f>": true
  },
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.whichwrap": "b,s,<,>,[,]",
  "vim.mouseSelectionGoesIntoVisualMode": true,
  "vim.normalModeKeyBindings": [
    {
      "before": ["<leader>", "w"],
      "commands": [":w"]
    },
    {
      "before": ["<leader>", "wa"],
      "commands": [":wa"]
    },
    {
      "before": ["<leader>", "wq"],
      "commands": [":wq"]
    },
    {
      "before": ["<leader>", "q"],
      "commands": [":q"]
    },
    {
      "before": ["<leader>", "qq"],
      "commands": [":qa!"]
    },
    {
      "before": ["<leader>", "qa"],
      "commands": [":wqa"]
    },
    {
      "before": ["s", "v"],
      "commands": [":vsp"]
    },
    {
      "before": ["s", "h"],
      "commands": [":sp"]
    },
    {
      "before": ["s", "c"],
      "commands": ["<C-w>", "c"]
    },
    {
      "before": ["s", "o"],
      "commands": ["<C-w>", "o"]
    },
    {
      "before": ["s", ","],
      "commands": [":vertical resize -10"]
    },
    {
      "before": ["s", "."],
      "commands": [":vertical resize +10"]
    },
    {
      "before": ["s", "j"],
      "commands": [":horizontal resize -5"]
    },
    {
      "before": ["s", "k"],
      "commands": [":horizontal resize +5"]
    },
    {
      "before": ["s", "="],
      "commands": ["<C-w>", "="]
    }
  ],
  "[python]": {
    "editor.formatOnType": true
  },
  "editor.unicodeHighlight.nonBasicASCII": false,
  "git.openRepositoryInParentFolders": "never",
  "[proto3]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "remote.SSH.remotePlatform": {
    "192.168.45.141": "linux"
  },
  "svg.preview.mode": "svg",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "zig.zls.path": "/home/delta/.config/Code/User/globalStorage/ziglang.vscode-zig/zls_install/zls",
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": false,
    "scminput": false
  },
  "terminal.integrated.fontFamily": "MesloLGS NF",
  // =================================== Nativate theme setting ===================================
  "window.titleBarStyle": "custom",
  "window.commandCenter": true,
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "One Dark Pro",
  // "workbench.preferredLightColorTheme": "One Light Pro",
  "editor.renderLineHighlight": "line",
  "workbench.tree.indent": 12,
  "workbench.colorTheme": "One Dark Pro",
  "cmake.configureOnOpen": true
}
